#!/usr/bin/env python3
import http.server
import urllib.request
import json
import sys
import os

API_KEY = os.environ.get('FOOTBALL_API_KEY', '4aead2463f6f4b3fa0df85affe7d98b9')
API_BASE = "https://api.football-data.org/v4"
PORT = int(os.environ.get('PORT', 8080))

class CORSProxyHandler(http.server.SimpleHTTPRequestHandler):
    protocol_version = 'HTTP/1.1'
    
    def log_message(self, format, *args):
        sys.stderr.write("[%s] %s\n" % (self.address_string(), format % args))
        sys.stderr.flush()
    
    def end_headers(self):
        self.send_header('Access-Control-Allow-Origin', '*')
        self.send_header('Access-Control-Allow-Methods', 'GET, OPTIONS')
        self.send_header('Access-Control-Allow-Headers', 'X-Auth-Token, Accept, Content-Type')
        self.send_header('Connection', 'keep-alive')
        super().end_headers()
    
    def do_OPTIONS(self):
        self.send_response(200)
        self.end_headers()
    
    def do_GET(self):
        print(f"[DEBUG] Request path: {self.path}", flush=True)
        
        if self.path.startswith('/api/'):
            api_path = self.path[5:]
            url = f"{API_BASE}/{api_path}"
            print(f"[DEBUG] Proxying to: {url}", flush=True)
            
            try:
                req = urllib.request.Request(url)
                req.add_header('X-Auth-Token', API_KEY)
                req.add_header('Accept', 'application/json')
                
                with urllib.request.urlopen(req, timeout=30) as response:
                    data = response.read()
                    
                    self.send_response(200)
                    self.send_header('Content-Type', 'application/json')
                    self.send_header('Content-Length', len(data))
                    self.end_headers()
                    self.wfile.write(data)
                    print(f"[DEBUG] Success: {len(data)} bytes returned", flush=True)
            except urllib.error.HTTPError as e:
                error_body = e.read() if e.fp else b'{}'
                print(f"[DEBUG] HTTP Error {e.code}: {error_body[:200]}", flush=True)
                self.send_response(e.code)
                self.send_header('Content-Type', 'application/json')
                self.send_header('Content-Length', len(error_body))
                self.end_headers()
                self.wfile.write(error_body)
            except Exception as e:
                print(f"[DEBUG] Exception: {e}", flush=True)
                error_msg = json.dumps({"error": str(e)}).encode()
                self.send_response(500)
                self.send_header('Content-Type', 'application/json')
                self.send_header('Content-Length', len(error_msg))
                self.end_headers()
                self.wfile.write(error_msg)
        else:
            if self.path == '/' or self.path == '':
                self.path = '/football-analyzer-v3.html'
            
            try:
                file_path = self.translate_path(self.path)
                if not os.path.exists(file_path):
                    self.send_error(404, "File not found")
                    return
                
                file_size = os.path.getsize(file_path)
                
                mime_type = 'text/html'
                if self.path.endswith('.css'):
                    mime_type = 'text/css'
                elif self.path.endswith('.js'):
                    mime_type = 'application/javascript'
                elif self.path.endswith('.json'):
                    mime_type = 'application/json'
                elif self.path.endswith('.png'):
                    mime_type = 'image/png'
                elif self.path.endswith('.ico'):
                    mime_type = 'image/x-icon'
                
                with open(file_path, 'rb') as f:
                    content = f.read()
                
                self.send_response(200)
                self.send_header('Content-Type', mime_type)
                self.send_header('Content-Length', file_size)
                self.end_headers()
                self.wfile.write(content)
                print(f"[DEBUG] Served: {self.path} ({file_size} bytes)", flush=True)
                
            except Exception as e:
                print(f"[DEBUG] File error: {e}", flush=True)
                self.send_error(500, str(e))

if __name__ == '__main__':
    server = http.server.HTTPServer(('0.0.0.0', PORT), CORSProxyHandler)
    print(f"Server running at http://0.0.0.0:{PORT}", flush=True)
    print("API proxy active - requests to /api/* will be proxied to football-data.org", flush=True)
    server.serve_forever()
