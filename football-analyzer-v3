        <div style="background: var(--bg-primary); border-radius: 8px; padding: 16px; margin-bottom: 16px;">
          <div style="font-weight: 600; margin-bottom: 12px;">📊 ${data.teamName} 多维度分析摘要</div>
          <div style="font-size: 13px; color: var(--text-secondary); line-height: 1.8;">
            <p>• 全场战绩: <strong style="color: var(--accent-win);">${a.fullTime.wins}胜</strong> <strong style="color: var(--accent-draw);">${a.fullTime.draws}平</strong> <strong style="color: var(--accent-lose);">${a.fullTime.losses}负</strong></p>
            <p>• 上半场战绩: <strong>${a.firstHalf.wins}胜${a.firstHalf.draws}平${a.firstHalf.losses}负</strong></p>
            <p>• 下半场战绩: <strong>${a.secondHalf.wins}胜${a.secondHalf.draws}平${a.secondHalf.losses}负</strong></p>
            <p>• 场均入球: <strong style="color: var(--accent-gold);">${c.goals.avgGoals.toFixed(1)}球</strong></p>
            <p>• 本队场均: <strong>${c.teamGoals.avgGoals.toFixed(1)}球</strong> | 对手场均: <strong>${c.opponentGoals.avgGoals.toFixed(1)}球</strong></p>
          </div>
        </div>
        <div style="background: linear-gradient(135deg, rgba(0, 217, 126, 0.1) 0%, rgba(59, 130, 246, 0.1) 100%); border-radius: 8px; padding: 16px;">
          <div style="font-weight: 600; margin-bottom: 8px;">🎯 综合预测结论</div>
          <div style="font-size: 14px; line-height: 1.8;">
            <p>• 全场胜率: <strong style="color: ${c.fullTime.winProb > 50 ? 'var(--accent-win)' : 'var(--text-secondary)'};">${c.fullTime.winProb.toFixed(1)}%</strong></p>
            <p>• 大球(2.5)概率: <strong style="color: ${c.goals.over25 > 55 ? 'var(--accent-win)' : 'var(--text-secondary)'};">${c.goals.over25.toFixed(1)}%</strong></p>
            <p>• 预测入球范围: <strong style="color: var(--accent-gold);">${c.goals.predictedRange}</strong></p>
          </div>
        </div>
      `;
    }
    
    async function loadMatches() {
      try {
        const today = new Date();
        const dateFrom = new Date(today);
        dateFrom.setDate(dateFrom.getDate() - 7);
        const dateTo = new Date(today);
        dateTo.setDate(dateTo.getDate() + 7);
        
        const fromStr = dateFrom.toISOString().split('T')[0];
        const toStr = dateTo.toISOString().split('T')[0];
        
        const data = await fetchAPI(`competitions/${currentLeague}/matches?dateFrom=${fromStr}&dateTo=${toStr}`);
        const matches = data.matches || [];
        
        const live = matches.filter(m => m.status === 'IN_PLAY' || m.status === 'LIVE');
        const upcoming = matches.filter(m => m.status === 'SCHEDULED' || m.status === 'TIMED');
        const finished = matches.filter(m => m.status === 'FINISHED');
        
        renderMatches('liveMatches', live, 'live');
        renderMatches('upcomingMatches', upcoming.slice(0, 10), 'upcoming');
        renderMatches('finishedMatches', finished.slice(-10).reverse(), 'finished');
        
      } catch (error) {
        console.error('Failed to load matches:', error);
        ['liveMatches', 'upcomingMatches', 'finishedMatches'].forEach(id => {
          document.getElementById(id).innerHTML = `
            <div class="empty-state">
              <div class="icon">❌</div>
              <p>加载失败</p>
            </div>
          `;
        });
      }
    }
    
    function renderMatches(containerId, matches, type) {
      const container = document.getElementById(containerId);
      
      if (matches.length === 0) {
        container.innerHTML = `
          <div class="empty-state">
            <div class="icon">⚽</div>
            <p>暂无${type === 'live' ? '进行中的' : type === 'upcoming' ? '即将开始的' : '已完赛的'}比赛</p>
          </div>
        `;
        return;
      }
      
      container.innerHTML = matches.map(match => {
        const homeTeam = getTeamNameCN(match.homeTeam.name);
        const awayTeam = getTeamNameCN(match.awayTeam.name);
        const homeScore = match.score.fullTime.home;
        const awayScore = match.score.fullTime.away;
        const matchTime = type === 'live' ? formatMatchTime(match.utcDate) : 
                         type === 'upcoming' ? formatMatchTime(match.utcDate) : formatDate(match.utcDate);
        
        return `
          <div class="match-item" onclick="showMatchAnalysis(${match.id})">
            <div class="match-time">${matchTime}</div>
            <div class="match-teams">
              <div class="team-name">${homeTeam}</div>
              <div class="match-score">
                ${type === 'upcoming' ? '<span style="color: var(--text-muted);">VS</span>' : 
                  `<span class="score-value ${type === 'live' ? 'score-live' : ''}">${homeScore}</span>
                   <span>:</span>
                   <span class="score-value ${type === 'live' ? 'score-live' : ''}">${awayScore}</span>`}
              </div>
              <div class="team-name">${awayTeam}</div>
            </div>
            ${type === 'live' ? '<span class="match-status status-live">进行中</span>' : ''}
            ${type === 'upcoming' ? '<span class="match-status status-upcoming">未开始</span>' : ''}
            ${type === 'finished' ? '<span class="match-status status-finished">完赛</span>' : ''}
          </div>
        `;
      }).join('');
    }
    
    async function loadStandings() {
      try {
        const data = await fetchAPI(`competitions/${currentLeague}/standings?season=${currentSeason}`);
        const table = data.standings?.[0]?.table || [];
        
        const tbody = document.getElementById('standingsBody');
        tbody.innerHTML = table.map((row, index) => {
          const rankClass = index < 3 ? `rank-${index + 1}` : '';
          return `
            <tr>
              <td class="standings-rank ${rankClass}">${row.position}</td>
              <td>
                <div class="standings-team">
                  <div class="team-logo"></div>
                  <span>${getTeamNameCN(row.team.name)}</span>
                </div>
              </td>
              <td class="standings-stats">${row.playedGames}</td>
              <td class="standings-stats">${row.won}</td>
              <td class="standings-stats">${row.draw}</td>
              <td class="standings-stats">${row.lost}</td>
              <td class="standings-stats" style="font-weight: 700; color: var(--accent-gold);">${row.points}</td>
            </tr>
          `;
        }).join('');
        
      } catch (error) {
        console.error('Failed to load standings:', error);
        document.getElementById('standingsBody').innerHTML = `
          <tr>
            <td colspan="7" class="empty-state">
              <div class="icon">❌</div>
              <p>加载积分榜失败</p>
            </td>
          </tr>
        `;
      }
    }
    
    function switchTab(tabName) {
      document.querySelectorAll('.nav-btn').forEach(btn => btn.classList.remove('active'));
      document.querySelector(`[data-tab="${tabName}"]`).classList.add('active');
      
      document.querySelectorAll('.tab-content').forEach(content => content.classList.remove('active'));
      document.getElementById(`${tabName}Tab`).classList.add('active');
      
      if (tabName === 'analysis') {
        loadTeams();
      } else if (tabName === 'standings') {
        loadStandings();
      }
    }
    
    function switchLeague(league) {
      currentLeague = league;
      document.querySelectorAll('.league-chip').forEach(chip => chip.classList.remove('active'));
      document.querySelector(`[data-league="${league}"]`).classList.add('active');
      
      loadMatches();
      
      const activeTab = document.querySelector('.tab-content.active').id.replace('Tab', '');
      if (activeTab === 'analysis') {
        loadTeams();
      } else if (activeTab === 'standings') {
        loadStandings();
      }
    }
    
    document.querySelectorAll('.nav-btn').forEach(btn => {
      btn.addEventListener('click', () => switchTab(btn.dataset.tab));
    });
    
    document.querySelectorAll('.league-chip').forEach(chip => {
      chip.addEventListener('click', () => switchLeague(chip.dataset.league));
    });
    
    document.getElementById('aiSendBtn').addEventListener('click', () => {
      const input = document.getElementById('aiInput');
      if (input.value.trim()) {
        showToast('AI功能需要配置API密钥', 'info');
        input.value = '';
      }
    });
    
    document.getElementById('aiInput').addEventListener('keypress', (e) => {
      if (e.key === 'Enter') {
        document.getElementById('aiSendBtn').click();
      }
    });
    
    function runBacktest(encodings, results) {
      if (encodings.length < 6) {
        return { accuracy: 0, predictions: [], message: '数据不足，至少需要6场比赛' };
      }
      
      let correctCount = 0;
      const predictions = [];
      
      for (let i = 5; i < encodings.length; i++) {
        const historicalEnc = encodings.slice(0, i);
        const last5Avg = historicalEnc.slice(-5).reduce((a, b) => a + b, 0) / 5;
        
        let predicted;
        if (last5Avg > 1) predicted = 1;
        else if (last5Avg < 0) predicted = 3;
        else predicted = 2;
        
        const actual = results[i];
        const isCorrect = predicted === actual;
        if (isCorrect) correctCount++;
        
        predictions.push({
          index: i + 1,
          avgEncoding: last5Avg.toFixed(2),
          predicted,
          actual,
          isCorrect
        });
      }
      
      const accuracy = predictions.length > 0 ? (correctCount / predictions.length * 100) : 0;
      
      return {
        accuracy,
        correctCount,
        totalPredictions: predictions.length,
        predictions: predictions.slice(-10),
        message: `准确率: ${accuracy.toFixed(1)}% (${correctCount}/${predictions.length})`
      };
    }
    
    function calculateConfidenceScore(features, opponentModel) {
      let score = 50;
      const factors = [];
      
      if (features.form > 1) {
        score += 15;
        factors.push('状态良好');
      } else if (features.form < -1) {
        score -= 15;
        factors.push('状态低迷');
      }
      
      if (features.consistency > 70) {
        score += 10;
        factors.push('发挥稳定');
      } else if (features.consistency < 40) {
        score -= 10;
        factors.push('波动较大');
      }
      
      if (opponentModel) {
        if (opponentModel.opponentStrength === 'weak') {
          score += 10;
          factors.push('对手较弱');
        } else if (opponentModel.opponentStrength === 'strong') {
          score -= 10;
          factors.push('对手较强');
        }
      }
      
      if (features.over25Rate > 60) {
        factors.push('大球倾向');
      }
      
      if (features.homeAdvantage > 60) {
        score += 5;
        factors.push('主场优势');
      }
      
      return {
        score: Math.max(10, Math.min(90, score)),
        level: score >= 70 ? 'high' : score >= 50 ? 'medium' : 'low',
        factors
      };
    }
    
    function init() {
      loadMatches();
      loadTeams();
    }
    
    init();
  </script>
