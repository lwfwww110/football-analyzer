    async function loadOpponentData(matches, teamId) {
      const opponents = new Map();
      
      const recentMatches = matches.slice(-5);
      
      for (const match of recentMatches) {
        const isHome = match.homeTeam.id === teamId;
        const opponentId = isHome ? match.awayTeam.id : match.homeTeam.id;
        const opponentName = isHome ? match.awayTeam.name : match.homeTeam.name;
        
        if (!opponents.has(opponentId)) {
          try {
            const oppData = await fetchAPI(`teams/${opponentId}/matches?status=FINISHED&season=${currentSeason}`);
            opponents.set(opponentId, {
              name: opponentName,
              matches: oppData.matches || [],
              analysis: null
            });
          } catch (e) {
            console.warn(`Failed to load opponent ${opponentName} data:`, e);
          }
        }
      }
      
      opponents.forEach((opp, id) => {
        if (opp.matches.length > 0) {
          opp.analysis = analyzeMultiDimension(opp.matches, parseInt(id));
        }
      });
      
      return opponents;
    }
    
    function combineTeamAndOpponent(teamAnalysis, opponentAnalyses, teamId) {
      if (!opponentAnalyses || opponentAnalyses.size === 0) {
        return {
          combinedWinProb: teamAnalysis.fullTime.wins / teamAnalysis.fullTime.encodings.length * 100,
          opponentFactor: 0,
          adjustedProb: teamAnalysis.fullTime.wins / teamAnalysis.fullTime.encodings.length * 100
        };
      }
      
      let totalOppWinRate = 0;
      let totalOppLossRate = 0;
      let opponentCount = 0;
      
      opponentAnalyses.forEach((opp) => {
        if (opp.analysis) {
          const oppWins = opp.analysis.fullTime.wins;
          const oppLosses = opp.analysis.fullTime.losses;
          const oppTotal = opp.analysis.fullTime.encodings.length;
          
          totalOppWinRate += oppWins / oppTotal;
          totalOppLossRate += oppLosses / oppTotal;
          opponentCount++;
        }
      });
      
      const avgOppWinRate = opponentCount > 0 ? totalOppWinRate / opponentCount : 0.5;
      const avgOppLossRate = opponentCount > 0 ? totalOppLossRate / opponentCount : 0.5;
      
      const teamWinRate = teamAnalysis.fullTime.wins / teamAnalysis.fullTime.encodings.length;
      
      const combinedWinProb = (teamWinRate * CONFIG.recentMatchWeight + (1 - avgOppWinRate) * CONFIG.opponentWeight) * 100;
      
      const opponentStrength = avgOppWinRate > 0.5 ? 'strong' : avgOppWinRate < 0.4 ? 'weak' : 'average';
      const opponentFactor = (avgOppWinRate - 0.5) * 20;
      
      return {
        combinedWinProb,
        opponentFactor,
        adjustedProb: Math.max(10, Math.min(90, combinedWinProb - opponentFactor)),
        opponentStrength,
        avgOppWinRate: avgOppWinRate * 100,
        avgOppLossRate: avgOppLossRate * 100,
        opponentCount
      };
    }
    
    function encodeMatch(match, isHome) {
      const homeScore = match.score.fullTime.home;
      const awayScore = match.score.fullTime.away;
      const isWin = isHome ? homeScore > awayScore : awayScore > homeScore;
      const isDraw = homeScore === awayScore;
      const isLoss = isHome ? homeScore < awayScore : awayScore < homeScore;
      
      if (isHome) {
        if (isWin) return 3;
        if (isDraw) return 1;
        if (isLoss) return -1;
      } else {
        if (isWin) return 4;
        if (isDraw) return 2;
        if (isLoss) return 0;
      }
      return 0;
    }
    
    const ENCODING_LABELS = {
      4: '客场胜(+4)',
      3: '主场胜(+3)',
      2: '客场平(+2)',
      1: '主场平(+1)',
      0: '客场负(0)',
      '-1': '主场负(-1)'
    };
    
    function calculateMatchPowerIndex(match, teamId) {
      const isHome = match.homeTeam.id === teamId;
      const homeScore = match.score.fullTime.home;
      const awayScore = match.score.fullTime.away;
      const totalGoals = homeScore + awayScore;
      
      let resCode = 0;
      const result = isHome 
        ? (homeScore > awayScore ? 'W' : homeScore < awayScore ? 'L' : 'D')
        : (awayScore > homeScore ? 'W' : awayScore < homeScore ? 'L' : 'D');
      
      if (result === 'W' && isHome) resCode = 3;
      else if (result === 'W' && !isHome) resCode = 4;
      else if (result === 'D') resCode = isHome ? 1 : 2;
      else if (result === 'L' && isHome) resCode = -1;
      else if (result === 'L' && !isHome) resCode = 0;
      
      const goalsFor = isHome ? homeScore : awayScore;
      const goalsAgainst = isHome ? awayScore : homeScore;
      const goalDiff = goalsFor - goalsAgainst;
      
      let sizeBase = totalGoals >= 3 ? 2 : 1;
      let sizeWeighted = sizeBase;
      
      if (totalGoals >= 3) {
        if (result === 'W' && isHome) {
          sizeWeighted = (goalDiff >= 2) ? 4 : 3;
        } else if (result === 'W' && !isHome) {
          sizeWeighted = 2 + goalDiff;
        } else if (result === 'L' && isHome) {
          sizeWeighted = 2 - Math.abs(goalDiff);
        } else {
          sizeWeighted = 2;
        }
      } else {
        if (result === 'W' && isHome) {
          sizeWeighted = 1;
        } else if (result === 'W' && !isHome) {
          sizeWeighted = 1 + goalDiff;
        } else if (result === 'L' && isHome) {
          sizeWeighted = 1 - Math.abs(goalDiff);
        } else {
          sizeWeighted = 1;
        }
      }
      
      const rawScore = (resCode + sizeWeighted + goalsFor) / 3;
      return rawScore - Math.floor(rawScore);
    }
    
    function calculatePowerLineTrend(matches, teamId) {
      if (matches.length < 3) return null;
      
      const sortedMatches = [...matches].sort((a, b) => new Date(a.utcDate) - new Date(b.utcDate));
      const powerIndices = sortedMatches.map(m => calculateMatchPowerIndex(m, teamId));
      
      const avgPower = powerIndices.reduce((a, b) => a + b, 0) / powerIndices.length;
      const recent3Avg = powerIndices.slice(-3).reduce((a, b) => a + b, 0) / 3;
      const recent5Avg = powerIndices.slice(-5).reduce((a, b) => a + b, 0) / Math.min(5, powerIndices.length);
      
      let trend = 'stable';
      if (recent3Avg > avgPower + 0.1) trend = 'rising';
      else if (recent3Avg < avgPower - 0.1) trend = 'falling';
      
      let signal = 'HOLD';
      let signalDesc = '暂无明显信号';
      
      if (trend === 'rising' && recent3Avg > 0.6) {
        signal = 'STRONG_BUY';
        signalDesc = '强势上升信号，状态火热';
      } else if (trend === 'falling' && recent3Avg < 0.3) {
        signal = 'VALUE_BUY';
        signalDesc = '潜在价值区，可能反弹';
      } else if (trend === 'falling' && recent3Avg > 0.5) {
        signal = 'STRONG_SELL';
        signalDesc = '强弩之末，注意回调';
      }
      
      return {
        powerIndices,
        avgPower,
        recent3Avg,
        recent5Avg,
        trend,
        signal,
        signalDesc
      };
    }
    
    function encodeHalfResult(halfHome, halfAway, isHome) {
      const isWin = isHome ? halfHome > halfAway : halfAway > halfHome;
      const isDraw = halfHome === halfAway;
      const isLoss = isHome ? halfHome < halfAway : halfAway < halfHome;
      
      if (isHome) {
        if (isWin) return 3;
        if (isDraw) return 1;
        if (isLoss) return -1;
      } else {
        if (isWin) return 4;
        if (isDraw) return 2;
        if (isLoss) return 0;
      }
      return 0;
    }
    
    function encodeGoals(goals) {
      if (goals === 0) return -2;
      if (goals === 1) return -1;
      if (goals === 2) return 0;
      if (goals === 3) return 1;
      if (goals === 4) return 2;
      return 3;
    }
    
    function encodeTeamGoals(goals, isHome) {
      if (goals === 0) return isHome ? -2 : -1;
      if (goals === 1) return isHome ? -1 : 0;
      if (goals === 2) return isHome ? 0 : 1;
      if (goals === 3) return isHome ? 1 : 2;
      return isHome ? 2 : 3;
    }
    
    function analyzeMultiDimension(matches, teamId) {
      const sortedMatches = [...matches].sort((a, b) => new Date(a.utcDate) - new Date(b.utcDate));
      
      const analysis = {
        fullTime: { encodings: [], homeEnc: [], awayEnc: [], wins: 0, draws: 0, losses: 0 },
        firstHalf: { encodings: [], homeEnc: [], awayEnc: [], wins: 0, draws: 0, losses: 0 },
        secondHalf: { encodings: [], homeEnc: [], awayEnc: [], wins: 0, draws: 0, losses: 0 },
        totalGoals: { encodings: [], values: [], avg: 0, over25: 0, over35: 0 },
        firstHalfGoals: { encodings: [], values: [], avg: 0 },
        secondHalfGoals: { encodings: [], values: [], avg: 0 },
        homeTeamGoals: { full: { encodings: [], values: [], avg: 0 }, first: { encodings: [], values: [], avg: 0 }, second: { encodings: [], values: [], avg: 0 } },
        awayTeamGoals: { full: { encodings: [], values: [], avg: 0 }, first: { encodings: [], values: [], avg: 0 }, second: { encodings: [], values: [], avg: 0 } },
        matchData: []
      };
      
      sortedMatches.forEach(match => {
        const isHome = match.homeTeam.id === teamId;
        
        const fullHome = match.score.fullTime.home;
        const fullAway = match.score.fullTime.away;
        const halfHome = match.score.halfTime?.home ?? 0;
        const halfAway = match.score.halfTime?.away ?? 0;
        
        const secondHalfHome = fullHome - halfHome;
        const secondHalfAway = fullAway - halfAway;
        
        const fullCode = encodeMatch(match, isHome);
        const firstHalfCode = encodeHalfResult(halfHome, halfAway, isHome);
        const secondHalfCode = encodeHalfResult(secondHalfHome, secondHalfAway, isHome);
        
        analysis.fullTime.encodings.push(fullCode);
        analysis.firstHalf.encodings.push(firstHalfCode);
        analysis.secondHalf.encodings.push(secondHalfCode);
        
        if (isHome) {
          analysis.fullTime.homeEnc.push(fullCode);
          analysis.firstHalf.homeEnc.push(firstHalfCode);
          analysis.secondHalf.homeEnc.push(secondHalfCode);
        } else {
          analysis.fullTime.awayEnc.push(fullCode);
          analysis.firstHalf.awayEnc.push(firstHalfCode);
          analysis.secondHalf.awayEnc.push(secondHalfCode);
        }
        
        if (fullCode >= 3) analysis.fullTime.wins++;
        else if (fullCode === 1 || fullCode === 2) analysis.fullTime.draws++;
        else analysis.fullTime.losses++;
        
        if (firstHalfCode >= 3) analysis.firstHalf.wins++;
        else if (firstHalfCode === 1 || firstHalfCode === 2) analysis.firstHalf.draws++;
        else analysis.firstHalf.losses++;
        
        if (secondHalfCode >= 3) analysis.secondHalf.wins++;
        else if (secondHalfCode === 1 || secondHalfCode === 2) analysis.secondHalf.draws++;
        else analysis.secondHalf.losses++;
        
        const totalGoals = fullHome + fullAway;
        const firstHalfGoals = halfHome + halfAway;
        const secondHalfGoals = secondHalfHome + secondHalfAway;
        
        analysis.totalGoals.encodings.push(encodeGoals(totalGoals));
        analysis.totalGoals.values.push(totalGoals);
        analysis.firstHalfGoals.encodings.push(encodeGoals(firstHalfGoals));
        analysis.firstHalfGoals.values.push(firstHalfGoals);
        analysis.secondHalfGoals.encodings.push(encodeGoals(secondHalfGoals));
        analysis.secondHalfGoals.values.push(secondHalfGoals);
        
        if (totalGoals > 2.5) analysis.totalGoals.over25++;
        if (totalGoals > 3.5) analysis.totalGoals.over35++;
        
        const teamFullGoals = isHome ? fullHome : fullAway;
        const teamFirstGoals = isHome ? halfHome : halfAway;
        const teamSecondGoals = isHome ? secondHalfHome : secondHalfAway;
        const oppFullGoals = isHome ? fullAway : fullHome;
        const oppFirstGoals = isHome ? halfAway : halfHome;
        const oppSecondGoals = isHome ? secondHalfAway : secondHalfHome;
        
        analysis.homeTeamGoals.full.encodings.push(encodeTeamGoals(teamFullGoals, true));
        analysis.homeTeamGoals.full.values.push(teamFullGoals);
        analysis.homeTeamGoals.first.encodings.push(encodeTeamGoals(teamFirstGoals, true));
        analysis.homeTeamGoals.first.values.push(teamFirstGoals);
        analysis.homeTeamGoals.second.encodings.push(encodeTeamGoals(teamSecondGoals, true));
        analysis.homeTeamGoals.second.values.push(teamSecondGoals);
        
        analysis.awayTeamGoals.full.encodings.push(encodeTeamGoals(oppFullGoals, false));
        analysis.awayTeamGoals.full.values.push(oppFullGoals);
        analysis.awayTeamGoals.first.encodings.push(encodeTeamGoals(oppFirstGoals, false));
        analysis.awayTeamGoals.first.values.push(oppFirstGoals);
        analysis.awayTeamGoals.second.encodings.push(encodeTeamGoals(oppSecondGoals, false));
        analysis.awayTeamGoals.second.values.push(oppSecondGoals);
        
        analysis.matchData.push({
          date: match.utcDate,
          opponent: isHome ? match.awayTeam.name : match.homeTeam.name,
          isHome,
          score: { fullHome, fullAway, halfHome, halfAway },
          codes: { full: fullCode, first: firstHalfCode, second: secondHalfCode }
        });
      });
      
      const n = sortedMatches.length;
      analysis.totalGoals.avg = analysis.totalGoals.values.reduce((a, b) => a + b, 0) / n;
      analysis.firstHalfGoals.avg = analysis.firstHalfGoals.values.reduce((a, b) => a + b, 0) / n;
      analysis.secondHalfGoals.avg = analysis.secondHalfGoals.values.reduce((a, b) => a + b, 0) / n;
      analysis.homeTeamGoals.full.avg = analysis.homeTeamGoals.full.values.reduce((a, b) => a + b, 0) / n;
      analysis.homeTeamGoals.first.avg = analysis.homeTeamGoals.first.values.reduce((a, b) => a + b, 0) / n;
      analysis.homeTeamGoals.second.avg = analysis.homeTeamGoals.second.values.reduce((a, b) => a + b, 0) / n;
      analysis.awayTeamGoals.full.avg = analysis.awayTeamGoals.full.values.reduce((a, b) => a + b, 0) / n;
      analysis.awayTeamGoals.first.avg = analysis.awayTeamGoals.first.values.reduce((a, b) => a + b, 0) / n;
      analysis.awayTeamGoals.second.avg = analysis.awayTeamGoals.second.values.reduce((a, b) => a + b, 0) / n;
      
      return analysis;
    }
    
    const CONFIG = {
      timeDecayLambda: 0.03,
      recentMatchWeight: 0.6,
      opponentWeight: 0.4,
      winThreshold: 55,
      over25Threshold: 60,
      over35Threshold: 50,
      homeAdvantageBonus: 5,
      features: {
        form: 0.3,
        goalDiff: 0.25,
        over25Rate: 0.2,
        homeAdvantage: 0.15,
        consistency: 0.1
      }
    };
    
    function calculateTimeWeight(matchDate, referenceDate = new Date()) {
      const matchTime = new Date(matchDate).getTime();
      const refTime = referenceDate.getTime();
      const daysDiff = (refTime - matchTime) / (1000 * 60 * 60 * 24);
      return Math.exp(-CONFIG.timeDecayLambda * daysDiff);
    }
    
    function calculateWeightedEncodings(encodings, matchDates, lastN = 10) {
      const recentEnc = encodings.slice(-lastN);
      const recentDates = matchDates.slice(-lastN);
      
      let weightedSum = 0;
      let totalWeight = 0;
      
      recentEnc.forEach((enc, i) => {
        const weight = calculateTimeWeight(recentDates[i]);
        weightedSum += enc * weight;
        totalWeight += weight;
      });
      
      return {
        weightedSum: totalWeight > 0 ? weightedSum / totalWeight : 0,
        rawSum: recentEnc.reduce((a, b) => a + b, 0),
        avgWeight: totalWeight / lastN
      };
    }
    
    function calculateMultiFeatures(analysis, matchDates, teamId) {
      const lastN = 10;
      const encodings = analysis.fullTime.encodings.slice(-lastN);
      const goals = analysis.totalGoals.values.slice(-lastN);
      const dates = matchDates.slice(-lastN);
      
      let formScore = 0;
      let goalDiffSum = 0;
      let over25Count = 0;
      let homeWins = 0;
      let homeGames = 0;
      let consistencyScore = 0;
      let totalWeight = 0;
      
      encodings.forEach((enc, i) => {
        const weight = calculateTimeWeight(dates[i]);
        formScore += enc * weight;
        goalDiffSum += (goals[i] - 2.5) * weight;
        if (goals[i] > 2.5) over25Count += weight;
        
        const match = analysis.matchData[analysis.matchData.length - lastN + i];
        if (match && match.isHome) {
          homeGames++;
          if (enc >= 3) homeWins++;
        }
        
        totalWeight += weight;
      });
      
      const meanEnc = encodings.reduce((a, b) => a + b, 0) / encodings.length;
      let variance = 0;
      encodings.forEach(enc => {
        variance += Math.pow(enc - meanEnc, 2);
      });
      consistencyScore = 1 / (1 + Math.sqrt(variance / encodings.length));
      
      return {
        form: totalWeight > 0 ? formScore / totalWeight : 0,
        goalDiff: totalWeight > 0 ? goalDiffSum / totalWeight : 0,
        over25Rate: totalWeight > 0 ? over25Count / totalWeight * 100 : 0,
        homeAdvantage: homeGames > 0 ? homeWins / homeGames * 100 : 50,
        consistency: consistencyScore * 100,
        rawSum: encodings.reduce((a, b) => a + b, 0)
      };
    }
    
    function calculatePrediction(encodings, lastN = 10) {
      const lastNEnc = encodings.slice(-lastN);
      const sum = lastNEnc.reduce((a, b) => a + b, 0);
      const avg = sum / lastN;
      
      let winProb = 0, drawProb = 0, loseProb = 0;
      
      if (sum >= 20) {
        winProb = 65 + Math.min(15, (sum - 20) * 1.5);
        drawProb = 20;
        loseProb = 100 - winProb - drawProb;
      } else if (sum >= 10) {
        winProb = 45 + (sum - 10) * 2;
        drawProb = 25;
        loseProb = 100 - winProb - drawProb;
      } else if (sum >= 0) {
        winProb = 30 + sum * 1.5;
        drawProb = 30;
        loseProb = 100 - winProb - drawProb;
      } else {
        winProb = Math.max(15, 30 + sum * 1.5);
        drawProb = 25;
        loseProb = 100 - winProb - drawProb;
      }
      
      return { sum, avg, winProb, drawProb, loseProb };
    }
    
    function calculateGoalsPrediction(encodings, values, lastN = 10) {
      const lastNVal = values.slice(-lastN);
      const lastNEnc = encodings.slice(-lastN);
      const sum = lastNEnc.reduce((a, b) => a + b, 0);
      const avgGoals = lastNVal.reduce((a, b) => a + b, 0) / lastN;
      
      const over25 = lastNVal.filter(v => v > 2.5).length / lastN * 100;
      const over35 = lastNVal.filter(v => v > 3.5).length / lastN * 100;
      const over45 = lastNVal.filter(v => v > 4.5).length / lastN * 100;
      
      let predictedRange = '0-2球';
      if (avgGoals >= 4) predictedRange = '4球以上';
      else if (avgGoals >= 3) predictedRange = '3-4球';
      else if (avgGoals >= 2) predictedRange = '2-3球';
      
      return { sum, avgGoals, over25, over35, over45, predictedRange };
    }
    
    function collisionAnalysis(analysis) {
      const fullPred = calculatePrediction(analysis.fullTime.encodings);
      const firstPred = calculatePrediction(analysis.firstHalf.encodings);
      const secondPred = calculatePrediction(analysis.secondHalf.encodings);
      const goalsPred = calculateGoalsPrediction(analysis.totalGoals.encodings, analysis.totalGoals.values);
      const firstGoalsPred = calculateGoalsPrediction(analysis.firstHalfGoals.encodings, analysis.firstHalfGoals.values);
      const secondGoalsPred = calculateGoalsPrediction(analysis.secondHalfGoals.encodings, analysis.secondHalfGoals.values);
      const teamGoalsPred = calculateGoalsPrediction(analysis.homeTeamGoals.full.encodings, analysis.homeTeamGoals.full.values);
      const teamFirstGoalsPred = calculateGoalsPrediction(analysis.homeTeamGoals.first.encodings, analysis.homeTeamGoals.first.values);
      const teamSecondGoalsPred = calculateGoalsPrediction(analysis.homeTeamGoals.second.encodings, analysis.homeTeamGoals.second.values);
      const oppGoalsPred = calculateGoalsPrediction(analysis.awayTeamGoals.full.encodings, analysis.awayTeamGoals.full.values);
      const oppFirstGoalsPred = calculateGoalsPrediction(analysis.awayTeamGoals.first.encodings, analysis.awayTeamGoals.first.values);
      const oppSecondGoalsPred = calculateGoalsPrediction(analysis.awayTeamGoals.second.encodings, analysis.awayTeamGoals.second.values);
      
      const signals = [];
      const conflicts = [];
      const recommendations = [];
      
      // ========== 维度间协同信号检测 ==========
      
      // 信号1: 全场胜 + 下半场胜 协同
      if (fullPred.winProb > 50 && secondPred.winProb > 55) {
        signals.push({
          type: 'synergy',
          name: '全场+下半场双胜信号',
          strength: (fullPred.winProb + secondPred.winProb) / 2,
          dimensions: ['全场胜平负', '下半场胜平负'],
          insight: '全场和下半场都指向胜利，球队整体实力占优'
        });
      }
      
      // 信号2: 全场胜 + 本队入球高 协同
      if (fullPred.winProb > 55 && teamGoalsPred.avgGoals > 1.8) {
        signals.push({
          type: 'synergy',
          name: '胜+进球双高信号',
          strength: Math.min(fullPred.winProb, teamGoalsPred.avgGoals * 30),
          dimensions: ['全场胜平负', '全场本队入球'],
          insight: `胜率${fullPred.winProb.toFixed(0)}%且场均入球${teamGoalsPred.avgGoals.toFixed(1)}，进攻效率高`
        });
      }
      
      // 信号3: 下半场胜 + 下半场入球高 协同
      if (secondPred.winProb > 55 && secondGoalsPred.avgGoals > 1.5) {
        signals.push({
          type: 'synergy',
          name: '下半场发力信号',
          strength: (secondPred.winProb + secondGoalsPred.avgGoals * 20) / 2,
          dimensions: ['下半场胜平负', '下半场总入球'],
          insight: '下半场胜率高且入球多，球队习惯后程发力'
        });
      }
      
      // 信号4: 大球 + 双方入球高 协同
      if (goalsPred.over25 > 60 && teamGoalsPred.avgGoals > 1.5 && oppGoalsPred.avgGoals > 1.2) {
        signals.push({
          type: 'synergy',
          name: '对攻大战信号',
          strength: (goalsPred.over25 + teamGoalsPred.avgGoals * 15 + oppGoalsPred.avgGoals * 15) / 3,
          dimensions: ['全场总入球', '全场本队入球', '全场客队入球'],
          insight: '双方进攻活跃，大球概率高'
        });
      }
      
      // 信号5: 上半场平/负 + 下半场胜 协同（逆转信号）
      if ((firstPred.drawProb > 35 || firstPred.loseProb > 40) && secondPred.winProb > 55) {
        signals.push({
          type: 'synergy',
          name: '逆转潜力信号',
          strength: secondPred.winProb,
          dimensions: ['上半场胜平负', '下半场胜平负'],
          insight: '上半场可能落后/平局，但下半场逆转能力强'
        });
      }
      
      // 信号6: 本队上半场入球低 + 下半场入球高 协同
      if (teamFirstGoalsPred.avgGoals < 0.8 && teamSecondGoalsPred.avgGoals > 1.2) {
        signals.push({
          type: 'synergy',
          name: '慢热型进攻信号',
          strength: teamSecondGoalsPred.avgGoals * 25,
          dimensions: ['上半场本队入球', '下半场本队入球'],
          insight: '上半场慢热，下半场进攻爆发'
        });
      }
      
      // ========== 维度间矛盾信号检测 ==========
      
      // 矛盾1: 全场胜率高 但 本队入球低
      if (fullPred.winProb > 55 && teamGoalsPred.avgGoals < 1.2) {
        conflicts.push({
          type: 'conflict',
          name: '胜率高但入球低',
          severity: 'medium',
          dimensions: ['全场胜平负', '全场本队入球'],
          insight: '胜率虽高但入球能力不足，可能是防守型球队，小胜概率大',
          alternative: '考虑小球或让球盘'
        });
      }
      
      // 矛盾2: 全场胜率高 但 下半场胜率低
      if (fullPred.winProb > 55 && secondPred.winProb < 40) {
        conflicts.push({
          type: 'conflict',
          name: '全场胜但下半场弱',
          severity: 'high',
          dimensions: ['全场胜平负', '下半场胜平负'],
          insight: '上半场表现好但下半场容易崩盘，领先时需警惕',
          alternative: '关注上半场投注或全场让球'
        });
      }
      
      // 矛盾3: 大球概率高 但 双方入球都低
      if (goalsPred.over25 > 60 && teamGoalsPred.avgGoals < 1.3 && oppGoalsPred.avgGoals < 1.3) {
        conflicts.push({
          type: 'conflict',
          name: '大球信号矛盾',
          severity: 'high',
          dimensions: ['全场总入球', '全场本队入球', '全场客队入球'],
          insight: '大球概率高但双方入球能力都弱，数据可能失真',
          alternative: '谨慎投注大球，考虑小球'
        });
      }
      
      // 矛盾4: 上半场胜率高 但 全场胜率低
      if (firstPred.winProb > 55 && fullPred.winProb < 45) {
        conflicts.push({
          type: 'conflict',
          name: '上半场强全场弱',
          severity: 'high',
          dimensions: ['上半场胜平负', '全场胜平负'],
          insight: '上半场领先但全场容易输，后劲不足',
          alternative: '投注上半场胜或半全场'
        });
      }
      
      // 矛盾5: 本队入球高 但 对手入球也高
      if (teamGoalsPred.avgGoals > 1.8 && oppGoalsPred.avgGoals > 1.5) {
        conflicts.push({
          type: 'conflict',
          name: '互攻型球队',
          severity: 'low',
          dimensions: ['全场本队入球', '全场客队入球'],
          insight: '进攻强但防守弱，比赛结果难以预测',
          alternative: '投注大球规避胜负风险'
        });
      }
      
      // ========== 多维特征组合分析 ==========
      
      // 组合1: 胜+大球+下半场发力
      if (fullPred.winProb > 50 && goalsPred.over25 > 55 && secondPred.winProb > 50) {
        recommendations.push({
          type: '胜+大球组合',
          confidence: (fullPred.winProb + goalsPred.over25 + secondPred.winProb) / 3,
          reason: `全场胜率${fullPred.winProb.toFixed(0)}% + 大球${goalsPred.over25.toFixed(0)}% + 下半场胜${secondPred.winProb.toFixed(0)}%，三重信号确认`,
          dimensions: ['全场胜平负', '全场总入球', '下半场胜平负'],
          risk: 'medium',
          strategy: '可双选胜+大球分散风险'
        });
      }
      
      // 组合2: 上半场落后风险 + 下半场逆转 + 大球
      if (firstPred.loseProb > 35 && secondPred.winProb > 50 && goalsPred.over25 > 55) {
        recommendations.push({
          type: '逆转大球策略',
          confidence: (secondPred.winProb + goalsPred.over25) / 2,
          reason: `上半场可能落后(${firstPred.loseProb.toFixed(0)}%)，但下半场逆转能力强(${secondPred.winProb.toFixed(0)}%)，大球概率${goalsPred.over25.toFixed(0)}%`,
          dimensions: ['上半场胜平负', '下半场胜平负', '全场总入球'],
          risk: 'high',
          strategy: '若上半场落后，投注大球或下半场入球更安全'
        });
      }
      
      // 组合3: 小胜策略（胜率高但入球少）
      if (fullPred.winProb > 55 && teamGoalsPred.avgGoals < 1.5 && oppGoalsPred.avgGoals < 1) {
        recommendations.push({
          type: '小胜策略',
          confidence: fullPred.winProb,
          reason: `胜率${fullPred.winProb.toFixed(0)}%但场均入球仅${teamGoalsPred.avgGoals.toFixed(1)}，防守型小胜`,
          dimensions: ['全场胜平负', '全场本队入球', '全场客队入球'],
          risk: 'low',
          strategy: '考虑让球盘或小球'
        });
      }
      
      // 组合4: 半全场策略
      if (firstPred.drawProb > 35 && secondPred.winProb > 55) {
        recommendations.push({
          type: '半全场策略',
          confidence: (firstPred.drawProb + secondPred.winProb) / 2,
          reason: `上半场平局概率${firstPred.drawProb.toFixed(0)}%，下半场胜率${secondPred.winProb.toFixed(0)}%`,
          dimensions: ['上半场胜平负', '下半场胜平负'],
          risk: 'medium',
          strategy: '考虑半全场：平-胜'
        });
      }
      
      // 组合5: 纯大球避险（胜负不确定但入球预期高）
      if (fullPred.winProb < 50 && fullPred.loseProb < 45 && goalsPred.over25 > 60) {
        recommendations.push({
          type: '大球避险',
          confidence: goalsPred.over25,
          reason: `胜负不确定(胜${fullPred.winProb.toFixed(0)}%/负${fullPred.loseProb.toFixed(0)}%)，但大球概率${goalsPred.over25.toFixed(0)}%`,
          dimensions: ['全场胜平负', '全场总入球'],
          risk: 'low',
          strategy: '投注大球规避胜负风险'
        });
      }
      
      // 组合6: 上半场入球策略
      if (firstGoalsPred.avgGoals > 1.2 && teamFirstGoalsPred.avgGoals > 0.7) {
        recommendations.push({
          type: '上半场入球',
          confidence: firstGoalsPred.avgGoals * 30,
          reason: `上半场场均${firstGoalsPred.avgGoals.toFixed(1)}球，本队上半场入球${teamFirstGoalsPred.avgGoals.toFixed(1)}`,
          dimensions: ['上半场总入球', '上半场本队入球'],
          risk: 'medium',
          strategy: '考虑上半场大球或首球投注'
        });
      }
      
      // 组合7: 下半场入球策略
      if (secondGoalsPred.avgGoals > 1.5 && firstGoalsPred.avgGoals < 1) {
        recommendations.push({
          type: '下半场入球爆发',
          confidence: secondGoalsPred.avgGoals * 25,
          reason: `上半场仅${firstGoalsPred.avgGoals.toFixed(1)}球，下半场${secondGoalsPred.avgGoals.toFixed(1)}球`,
          dimensions: ['上半场总入球', '下半场总入球'],
          risk: 'medium',
          strategy: '关注下半场大球或滚球投注'
        });
      }
      
      // 组合8: 客队入球策略
      if (oppGoalsPred.avgGoals > 1.5 && oppSecondGoalsPred.avgGoals > 0.8) {
        recommendations.push({
          type: '客队入球机会',
          confidence: oppGoalsPred.avgGoals * 25,
          reason: `对手场均入球${oppGoalsPred.avgGoals.toFixed(1)}，下半场${oppSecondGoalsPred.avgGoals.toFixed(1)}球`,
          dimensions: ['全场客队入球', '下半场客队入球'],
          risk: 'high',
          strategy: '考虑双方进球或客队入球盘'
        });
      }
      
      recommendations.sort((a, b) => b.confidence - a.confidence);
      signals.sort((a, b) => b.strength - a.strength);
      conflicts.sort((a, b) => a.severity === 'high' ? -1 : 1);
      
      return {
        fullTime: fullPred,
        firstHalf: firstPred,
        secondHalf: secondPred,
        goals: goalsPred,
        firstHalfGoals: firstGoalsPred,
        secondHalfGoals: secondGoalsPred,
        teamGoals: teamGoalsPred,
        teamFirstGoals: teamFirstGoalsPred,
        teamSecondGoals: teamSecondGoalsPred,
        opponentGoals: oppGoalsPred,
        opponentFirstGoals: oppFirstGoalsPred,
        opponentSecondGoals: oppSecondGoalsPred,
        signals: signals.slice(0, 6),
        conflicts: conflicts.slice(0, 4),
        recommendations: recommendations.slice(0, 8)
      };
    }
    
    function runAnalysis(teamName, matches, opponentData) {
      const analysis = analyzeMultiDimension(matches, selectedTeam.id);
      const collision = collisionAnalysis(analysis);
      const opponentModel = combineTeamAndOpponent(analysis, opponentData, selectedTeam.id);
      const powerLineTrend = calculatePowerLineTrend(matches, selectedTeam.id);
      
      const matchDates = matches.map(m => m.utcDate);
      const features = calculateMultiFeatures(analysis, matchDates, selectedTeam.id);
      
      renderMultiDimensionAnalysis({
        teamName,
        totalMatches: matches.length,
        analysis,
        collision,
        opponentModel,
        features,
        opponentData,
        powerLineTrend,
        matchDates,
        matches
      });
    }
    
