    function extractFeatures(match, teamId) {
      const isHome = match.homeTeam.id === teamId;
      const homeScore = match.score.fullTime.home || 0;
      const awayScore = match.score.fullTime.away || 0;
      const totalGoals = homeScore + awayScore;
      
      const encoding = encodeMatch(match, isHome);
      const goals = isHome ? homeScore : awayScore;
      const homeAdv = isHome ? 1 : 0;
      
      const powerIndex = calculateMatchPowerIndex(match, teamId);
      
      return {
        encoding: (encoding + 1) / 5,
        goals: goals / 5,
        home: homeAdv,
        form: 0.5,
        over: totalGoals > 2.5 ? 1 : 0,
        power: powerIndex
      };
    }
    
    function sigmoid(x) {
      return 1 / (1 + Math.exp(-x));
    }
    
    function trainModel() {
      if (mlDataset.length < 10) {
        mlLog('错误: 数据量不足，至少需要10条数据');
        showToast('数据量不足', 'error');
        return;
      }
      
      mlLog('开始训练 Logistic Regression 模型...');
      mlLog(`训练数据: ${mlDataset.length} 条`);
      
      const learningRate = 0.1;
      const iterations = 1000;
      
      let w_encoding = 0.5, w_goals = 0.5, w_home = 0.5, w_form = 0.5, w_over = 0.5, w_power = 0.5;
      let bias = 0;
      
      for (let iter = 0; iter < iterations; iter++) {
        let totalLoss = 0;
        let dEncoding = 0, dGoals = 0, dHome = 0, dForm = 0, dOver = 0, dPower = 0, dBias = 0;
        
        mlDataset.forEach(data => {
          const f = data.features;
          const y = data.label;
          
          const z = w_encoding * f.encoding + w_goals * f.goals + w_home * f.home + 
                    w_form * f.form + w_over * f.over + w_power * f.power + bias;
          const pred = sigmoid(z);
          
          const error = pred - y;
          totalLoss += error * error;
          
          dEncoding += error * f.encoding;
          dGoals += error * f.goals;
          dHome += error * f.home;
          dForm += error * f.form;
          dOver += error * f.over;
          dPower += error * f.power;
          dBias += error;
        });
        
        const n = mlDataset.length;
        w_encoding -= learningRate * dEncoding / n;
        w_goals -= learningRate * dGoals / n;
        w_home -= learningRate * dHome / n;
        w_form -= learningRate * dForm / n;
        w_over -= learningRate * dOver / n;
        w_power -= learningRate * dPower / n;
        bias -= learningRate * dBias / n;
        
        if (iter % 200 === 0) {
          mlLog(`迭代 ${iter}: Loss = ${(totalLoss / n).toFixed(4)}`);
        }
      }
      
      mlWeights = {
        encoding: w_encoding,
        goals: w_goals,
        home: w_home,
        form: w_form,
        over: w_over,
        power: w_power
      };
      mlModel = { weights: mlWeights, bias: bias };
      
      document.getElementById('weight_encoding').textContent = w_encoding.toFixed(3);
      document.getElementById('weight_goals').textContent = w_goals.toFixed(3);
      document.getElementById('weight_home').textContent = w_home.toFixed(3);
      document.getElementById('weight_form').textContent = w_form.toFixed(3);
      document.getElementById('weight_over').textContent = w_over.toFixed(3);
      document.getElementById('weight_power').textContent = w_power.toFixed(3);
      
      document.getElementById('mlStatus').textContent = '已训练';
      document.getElementById('mlStatus').style.color = 'var(--accent-win)';
      
      mlLog('训练完成!');
      mlLog(`最终权重: encoding=${w_encoding.toFixed(3)}, goals=${w_goals.toFixed(3)}, home=${w_home.toFixed(3)}, form=${w_form.toFixed(3)}, over=${w_over.toFixed(3)}, power=${w_power.toFixed(3)}`);
      mlLog(`Bias: ${bias.toFixed(3)}`);
      
      showToast('模型训练完成!', 'success');
    }
    
    function validateModel() {
      if (!mlModel || mlDataset.length < 10) {
        mlLog('错误: 请先训练模型');
        showToast('请先训练模型', 'error');
        return;
      }
      
      mlLog('开始验证模型...');
      
      let correct = 0;
      let total = 0;
      const confusion = { tp: 0, tn: 0, fp: 0, fn: 0 };
      
      const testSize = Math.floor(mlDataset.length * 0.2);
      const testData = mlDataset.slice(-testSize);
      
      testData.forEach(data => {
        const f = data.features;
        const w = mlModel.weights;
        
        const z = w.encoding * f.encoding + w.goals * f.goals + w.home * f.home + 
                  w.form * f.form + w.over * f.over + w.power * f.power + mlModel.bias;
        const pred = sigmoid(z);
        
        const predicted = pred > 0.5 ? 1 : (pred < 0.5 ? 0 : 0.5);
        const actual = data.label;
        
        if (Math.abs(predicted - actual) < 0.1) {
          correct++;
        }
        total++;
        
        if (actual === 1 && predicted === 1) confusion.tp++;
        else if (actual === 0 && predicted === 0) confusion.tn++;
        else if (actual === 1 && predicted === 0) confusion.fn++;
        else if (actual === 0 && predicted === 1) confusion.fp++;
      });
      
      const accuracy = (correct / total * 100).toFixed(1);
      
      document.getElementById('mlAccuracy').textContent = accuracy + '%';
      
      mlLog(`验证完成: ${correct}/${total} 正确`);
      mlLog(`准确率: ${accuracy}%`);
      mlLog(`混淆矩阵: TP=${confusion.tp}, TN=${confusion.tn}, FP=${confusion.fp}, FN=${confusion.fn}`);
      
      const precision = confusion.tp / (confusion.tp + confusion.fp) || 0;
      const recall = confusion.tp / (confusion.tp + confusion.fn) || 0;
      const f1 = 2 * precision * recall / (precision + recall) || 0;
      
      mlLog(`精确率: ${(precision * 100).toFixed(1)}%`);
      mlLog(`召回率: ${(recall * 100).toFixed(1)}%`);
      mlLog(`F1分数: ${f1.toFixed(3)}`);
      
      showToast(`验证完成: 准确率 ${accuracy}%`, 'success');
    }
    
    function runROIBacktest() {
      if (!mlModel) {
        showToast('请先训练模型', 'error');
        return;
      }
      
      const minProb = parseFloat(document.getElementById('minProbThreshold').value) || 0.6;
      const initialBankroll = parseFloat(document.getElementById('initialBankroll').value) || 1000;
      
      mlLog(`开始ROI回测... 最小概率阈值: ${minProb}`);
      
      let bankroll = initialBankroll;
      let bets = 0;
      let wins = 0;
      
      mlDataset.slice(0, -10).forEach((data, i) => {
        const f = data.features;
        const w = mlModel.weights;
        
        const z = w.encoding * f.encoding + w.goals * f.goals + w.home * f.home + 
                  w.form * f.form + w.over * f.over + w.power * f.power + mlModel.bias;
        const prob = sigmoid(z);
        
        if (prob > minProb) {
          const betAmount = bankroll * 0.02;
          bankroll -= betAmount;
          bets++;
          
          if (data.label === 1) {
            const odds = 1.5 + (1 - prob) * 2;
            bankroll += betAmount * odds;
            wins++;
          }
        }
      });
      
      const roi = ((bankroll - initialBankroll) / initialBankroll * 100).toFixed(1);
      
      document.getElementById('roiResult').innerHTML = `
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px;">
          <div style="text-align: center; padding: 12px; background: var(--bg-secondary); border-radius: 8px;">
            <div style="font-size: 11px; color: var(--text-secondary);">总投注次数</div>
            <div style="font-size: 20px; font-weight: 700;">${bets}</div>
          </div>
          <div style="text-align: center; padding: 12px; background: var(--bg-secondary); border-radius: 8px;">
            <div style="font-size: 11px; color: var(--text-secondary);">胜率</div>
            <div style="font-size: 20px; font-weight: 700; color: ${wins/bets > 0.5 ? 'var(--accent-win)' : 'var(--accent-lose)'};">${bets > 0 ? (wins/bets*100).toFixed(1) : 0}%</div>
          </div>
          <div style="text-align: center; padding: 12px; background: var(--bg-secondary); border-radius: 8px;">
            <div style="font-size: 11px; color: var(--text-secondary);">ROI</div>
            <div style="font-size: 20px; font-weight: 700; color: ${roi > 0 ? 'var(--accent-win)' : 'var(--accent-lose)'};">${roi}%</div>
          </div>
        </div>
        <div style="margin-top: 12px; text-align: center; font-size: 14px;">
          最终资金: <strong style="color: ${bankroll > initialBankroll ? 'var(--accent-win)' : 'var(--accent-lose)'};">$${bankroll.toFixed(2)}</strong>
        </div>
      `;
      
      mlLog(`ROI回测完成: ${bets}次投注, ${wins}次胜利, ROI=${roi}%`);
      showToast('ROI回测完成', 'success');
    }
    
    function predictWithModel(features) {
      if (!mlModel) return null;
      
      const w = mlModel.weights;
      const z = w.encoding * features.encoding + w.goals * features.goals + w.home * features.home + 
                w.form * features.form + w.over * features.over + w.power * features.power + mlModel.bias;
      
      return sigmoid(z);
    }
    
