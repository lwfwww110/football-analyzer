      const maxVal = 1;
      
      let bars = '';
      for (let i = 0; i < n; i++) {
        const val = powerIndices[i];
        const heightPercent = (val / maxVal) * 100;
        const color = val > 0.6 ? 'var(--accent-win)' : val < 0.4 ? 'var(--accent-lose)' : 'var(--accent-gold)';
        const left = 30 + (i / (n - 1)) * 65;
        
        bars += `
          <div style="position: absolute; bottom: 20px; left: ${left}%; width: ${barWidth}px; height: ${heightPercent}%; background: ${color}; border-radius: 2px 2px 0 0; transform: translateX(-50%); opacity: 0.8;" title="第${i+1}场: ${val.toFixed(3)}"></div>
          <div style="position: absolute; bottom: 5px; left: ${left}%; transform: translateX(-50%); font-size: 8px; color: var(--text-muted);">${i+1}</div>
        `;
      }
      
      return `
        <div style="position: absolute; left: 5px; top: 10px; font-size: 9px; color: var(--text-muted);">1.0</div>
