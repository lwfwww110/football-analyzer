              <div style="font-size: 11px; color: var(--text-secondary);">信号</div>
              <div style="font-size: 14px; font-weight: 700; color: ${data.powerLineTrend.signal === 'STRONG_BUY' ? 'var(--accent-win)' : data.powerLineTrend.signal === 'STRONG_SELL' ? 'var(--accent-lose)' : data.powerLineTrend.signal === 'VALUE_BUY' ? 'var(--accent-blue)' : 'var(--accent-draw)'};">
                ${data.powerLineTrend.signal === 'STRONG_BUY' ? '强势买入' : data.powerLineTrend.signal === 'STRONG_SELL' ? '强势卖出' : data.powerLineTrend.signal === 'VALUE_BUY' ? '价值买入' : '持有观望'}
