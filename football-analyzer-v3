      logEl.innerHTML += `<div style="margin: 2px 0;">[${time}] ${message}</div>`;
      logEl.scrollTop = logEl.scrollHeight;
    }
    
    function buildDataset() {
      mlLog('开始构建数据集...');
      mlDataset = [];
      
      let totalMatches = 0;
      
      Object.keys(matchesCache).forEach(league => {
        const matches = matchesCache[league];
        if (!matches) return;
        
        matches.forEach(match => {
          if (match.status !== 'FINISHED') return;
          
          const homeTeam = match.homeTeam;
          const awayTeam = match.awayTeam;
          const homeScore = match.score.fullTime.home;
          const awayScore = match.score.fullTime.away;
          
          if (homeScore == null || awayScore == null) return;
          
          let label;
          if (homeScore > awayScore) label = 1;
          else if (homeScore < awayScore) label = 0;
          else label = 0.5;
          
          const features = extractFeatures(match, homeTeam.id);
          
          mlDataset.push({
            features: features,
            label: label,
            match: `${homeTeam.name} vs ${awayTeam.name}`,
            date: match.utcDate
          });
          
          totalMatches++;
        });
      });
      
      document.getElementById('mlDataCount').textContent = mlDataset.length;
      mlLog(`数据集构建完成: ${mlDataset.length} 条记录`);
      
