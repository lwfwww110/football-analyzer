        <div style="margin-top: 16px; background: linear-gradient(135deg, rgba(251, 191, 36, 0.1) 0%, rgba(59, 130, 246, 0.1) 100%); border-radius: 12px; padding: 16px;">
          <div style="font-size: 15px; font-weight: 600; margin-bottom: 12px; display: flex; align-items: center; gap: 8px;">
            💡 智能投注建议
          </div>
          ${c.recommendations.length > 0 ? c.recommendations.map(rec => `
            <div style="background: var(--bg-primary); border-radius: 8px; padding: 12px; margin-bottom: 8px;">
              <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px;">
                <span style="font-weight: 600; color: var(--accent-gold);">${rec.type}</span>
                <span style="font-size: 12px; padding: 2px 8px; background: var(--accent-win); color: #000; border-radius: 4px;">置信度 ${rec.confidence.toFixed(0)}%</span>
              </div>
              <div style="font-size: 13px; color: var(--text-secondary);">${rec.reason}</div>
            </div>
          `).join('') : '<div style="text-align: center; color: var(--text-muted);">暂无明确建议</div>'}
        </div>
        
        ${(() => {
          const encodings = a.fullTime.encodings;
          const results = encodings.map(e => e >= 3 ? 1 : (e === 1 || e === 2) ? 2 : 3);
          const backtest = runBacktest(encodings, results);
          const confidence = calculateConfidenceScore(data.features, data.opponentModel);
          
          return `
          <div style="margin-top: 16px; background: var(--bg-secondary); border-radius: 12px; padding: 16px;">
            <div style="font-size: 15px; font-weight: 600; margin-bottom: 12px;">📈 回测验证 & 置信度</div>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
              <div style="background: var(--bg-primary); border-radius: 8px; padding: 12px; text-align: center;">
                <div style="font-size: 12px; color: var(--text-secondary);">历史预测准确率</div>
                <div style="font-size: 24px; font-weight: 700; color: ${backtest.accuracy > 50 ? 'var(--accent-win)' : 'var(--accent-lose)'};">${backtest.accuracy.toFixed(1)}%</div>
                <div style="font-size: 11px; color: var(--text-muted);">${backtest.correctCount}/${backtest.totalPredictions}场正确</div>
              </div>
              <div style="background: var(--bg-primary); border-radius: 8px; padding: 12px; text-align: center;">
                <div style="font-size: 12px; color: var(--text-secondary);">综合置信度</div>
                <div style="font-size: 24px; font-weight: 700; color: ${confidence.level === 'high' ? 'var(--accent-win)' : confidence.level === 'medium' ? 'var(--accent-draw)' : 'var(--accent-lose)'};">${confidence.score}%</div>
                <div style="font-size: 11px; color: var(--text-muted);">${confidence.level === 'high' ? '高置信度' : confidence.level === 'medium' ? '中等置信度' : '低置信度'}</div>
              </div>
            </div>
            ${confidence.factors.length > 0 ? `
            <div style="margin-top: 12px; font-size: 12px; color: var(--text-secondary);">
              <strong>评分因素：</strong>${confidence.factors.join(' | ')}
