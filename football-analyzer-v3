    function updateOddsComparison(data) {
      const container = document.getElementById('oddsComparisonResult');
      if (!container || !currentOdds.win || !data.powerLineTrend) return;
      
      const winProb = (1 / currentOdds.win) * 100;
      const drawProb = (1 / currentOdds.draw) * 100;
      const loseProb = (1 / currentOdds.lose) * 100;
      const total = winProb + drawProb + loseProb;
      
      const normalizedWin = winProb / total * 100;
      const normalizedDraw = drawProb / total * 100;
      const normalizedLose = loseProb / total * 100;
      
      const powerIndex = data.powerLineTrend.recent3Avg;
      let powerWinProb, powerDrawProb, powerLoseProb;
      
      if (powerIndex > 0.6) {
        powerWinProb = 50 + (powerIndex - 0.5) * 100;
        powerDrawProb = 25;
        powerLoseProb = 25 - (powerIndex - 0.5) * 50;
      } else if (powerIndex < 0.4) {
        powerWinProb = 25 - (0.5 - powerIndex) * 50;
        powerDrawProb = 25;
        powerLoseProb = 50 + (0.5 - powerIndex) * 100;
      } else {
        powerWinProb = 35 + (powerIndex - 0.4) * 50;
        powerDrawProb = 30;
        powerLoseProb = 35 - (powerIndex - 0.4) * 50;
      }
      
      powerWinProb = Math.max(10, Math.min(70, powerWinProb));
      powerDrawProb = Math.max(15, Math.min(40, powerDrawProb));
      powerLoseProb = Math.max(10, Math.min(70, powerLoseProb));
      
      const powerTotal = powerWinProb + powerDrawProb + powerLoseProb;
      powerWinProb = powerWinProb / powerTotal * 100;
      powerDrawProb = powerDrawProb / powerTotal * 100;
      powerLoseProb = powerLoseProb / powerTotal * 100;
      
      const winDiff = powerWinProb - normalizedWin;
      const drawDiff = powerDrawProb - normalizedDraw;
      const loseDiff = powerLoseProb - normalizedLose;
      
      let divergence = 'NORMAL';
      let divergenceDesc = '实力线与赔率基本一致';
      let divergenceColor = 'var(--accent-draw)';
      
      if (winDiff > 10) {
        divergence = 'GOLDEN_RESONANCE';
        divergenceDesc = '黄金共振：实力线显示主胜概率高于赔率，存在价值投注机会';
        divergenceColor = 'var(--accent-win)';
      } else if (loseDiff > 10) {
        divergence = 'VALUE_LOSE';
        divergenceDesc = '实力线显示客胜概率高于赔率，可能存在冷门机会';
        divergenceColor = 'var(--accent-blue)';
      } else if (winDiff < -10) {
        divergence = 'DEVIL_DIVERGENCE';
        divergenceDesc = '魔鬼背离：赔率看好主胜但实力线不支撑，需谨慎';
        divergenceColor = 'var(--accent-lose)';
      }
      
      container.innerHTML = `
        <div style="margin-top: 12px; background: var(--bg-primary); border-radius: 8px; padding: 12px;">
          <div style="font-size: 13px; font-weight: 600; margin-bottom: 10px; color: var(--accent-blue);">📊 实力线 vs 赔率对比</div>
          
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 12px;">
            <div>
              <div style="font-size: 11px; color: var(--text-secondary); margin-bottom: 6px;">实力线预测</div>
              <div style="display: flex; height: 24px; border-radius: 4px; overflow: hidden;">
                <div style="width: ${powerWinProb}%; background: var(--accent-win);"></div>
                <div style="width: ${powerDrawProb}%; background: var(--accent-draw);"></div>
                <div style="width: ${powerLoseProb}%; background: var(--accent-lose);"></div>
              </div>
              <div style="display: flex; justify-content: space-between; font-size: 10px; margin-top: 4px; color: var(--text-muted);">
                <span style="color: var(--accent-win);">${powerWinProb.toFixed(1)}%</span>
                <span style="color: var(--accent-draw);">${powerDrawProb.toFixed(1)}%</span>
                <span style="color: var(--accent-lose);">${powerLoseProb.toFixed(1)}%</span>
              </div>
            </div>
            <div>
              <div style="font-size: 11px; color: var(--text-secondary); margin-bottom: 6px;">赔率隐含概率</div>
              <div style="display: flex; height: 24px; border-radius: 4px; overflow: hidden;">
                <div style="width: ${normalizedWin}%; background: var(--accent-win);"></div>
                <div style="width: ${normalizedDraw}%; background: var(--accent-draw);"></div>
                <div style="width: ${normalizedLose}%; background: var(--accent-lose);"></div>
              </div>
              <div style="display: flex; justify-content: space-between; font-size: 10px; margin-top: 4px; color: var(--text-muted);">
                <span style="color: var(--accent-win);">${normalizedWin.toFixed(1)}%</span>
                <span style="color: var(--accent-draw);">${normalizedDraw.toFixed(1)}%</span>
                <span style="color: var(--accent-lose);">${normalizedLose.toFixed(1)}%</span>
              </div>
            </div>
          </div>
          
          <div style="padding: 10px; border-radius: 6px; background: rgba(255,255,255,0.03); border-left: 3px solid ${divergenceColor};">
            <div style="font-weight: 600; margin-bottom: 4px; color: ${divergenceColor};">
              ${divergence === 'GOLDEN_RESONANCE' ? '✨ 黄金共振' : divergence === 'DEVIL_DIVERGENCE' ? '⚠️ 魔鬼背离' : divergence === 'VALUE_LOSE' ? '💎 价值冷门' : '➡️ 正常区间'}
            </div>
            <div style="font-size: 12px; color: var(--text-secondary);">${divergenceDesc}</div>
          </div>
          
          <div style="margin-top: 10px; font-size: 11px; color: var(--text-muted);">
            差异: 主胜 ${winDiff > 0 ? '+' : ''}${winDiff.toFixed(1)}% | 平局 ${drawDiff > 0 ? '+' : ''}${drawDiff.toFixed(1)}% | 客胜 ${loseDiff > 0 ? '+' : ''}${loseDiff.toFixed(1)}%
          </div>
        </div>
      `;
    }
    
    function renderPowerLineBars(powerIndices) {
      if (!powerIndices || powerIndices.length < 2) {
        return '<div style="display: flex; align-items: center; justify-content: center; height: 100%; color: var(--text-muted); font-size: 12px;">需要更多数据</div>';
