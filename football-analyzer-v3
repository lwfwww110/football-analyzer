              <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px;">
                <span style="font-weight: 600; color: var(--accent-win);">${sig.name}</span>
                <span style="font-size: 12px; padding: 2px 8px; background: rgba(0, 217, 126, 0.2); color: var(--accent-win); border-radius: 4px;">强度 ${sig.strength.toFixed(0)}%</span>
